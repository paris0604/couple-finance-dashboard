# ════════════════════════════════════════════════════════════════
# Google Sheets 연동 설정
# 이 파일을 같은 폴더에 secrets.toml 로 복사한 뒤, 아래 URL 2줄만 채우면 됩니다.
#
# 서비스 계정 키(JSON)는 여기에 옮겨 적지 않아도 됩니다.
# 다운로드한 JSON 파일을  .streamlit/service_account.json  이름으로 저장하면
# 앱이 자동으로 인식합니다. (가장 간단한 방법)
# ════════════════════════════════════════════════════════════════

# ── 스프레드시트 URL (브라우저 주소창 전체를 그대로 붙여넣기) ──────
ledger_spreadsheet_url = "https://docs.google.com/spreadsheets/d/가계부_시트ID/edit"     # 읽기·쓰기
invest_spreadsheet_url = "https://docs.google.com/spreadsheets/d/포트폴리오_시트ID/edit"  # 읽기 전용

# ── (선택) 탭(시트) 이름이 기본값과 다를 때만 지정 ──────────────
# 기본값: 가계부 → "가계부",  투자 → "transactions"
# 탭 이름을 바꿨다면 여기에 새 이름을 적으면 코드 수정 없이 인식됩니다.
# ledger_tab_name = "가계부"
# invest_tab_name = "transactions"


# ════════════════════════════════════════════════════════════════
# (선택) JSON 파일을 쓰지 않고 키를 직접 적고 싶을 때만 아래 사용.
# 위의 service_account.json 방식을 쓰면 이 섹션은 통째로 지워도 됩니다.
# ════════════════════════════════════════════════════════════════
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
